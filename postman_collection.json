{
  "info": {
    "name": "AI Voice Calling Agent Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "token", "value": "" },
    { "key": "agent_id", "value": "" },
    { "key": "customer_id", "value": "" },
    { "key": "call_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"changeme123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Agents",
      "item": [
        {
          "name": "Create Agent",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/agents",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admission Counselor\",\n  \"description\": \"Handles admission inquiries\",\n  \"voice\": \"Rachel\",\n  \"language\": \"en\",\n  \"temperature\": 0.4,\n  \"prompt\": \"You are an admission counselor. Speak politely. Ask only one question at a time.\",\n  \"greeting_message\": \"Hi! Thanks for your interest in our programs.\"\n}"
            }
          }
        },
        {
          "name": "List Agents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/agents"
          }
        },
        {
          "name": "Update Agent",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/agents/{{agent_id}}",
            "body": { "mode": "raw", "raw": "{\n  \"temperature\": 0.5\n}" }
          }
        },
        {
          "name": "Delete Agent",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/agents/{{agent_id}}"
          }
        }
      ]
    },
    {
      "name": "Knowledge Base",
      "item": [
        {
          "name": "Upload Knowledge File",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/knowledge/upload?agent_id={{agent_id}}",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/customers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Doe\",\n  \"phone\": \"+919999999999\",\n  \"city\": \"Mumbai\",\n  \"state\": \"Maharashtra\"\n}"
            }
          }
        },
        {
          "name": "List Customers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/customers"
          }
        }
      ]
    },
    {
      "name": "Campaigns",
      "item": [
        {
          "name": "Create Campaign",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/campaign",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Fall Admissions Drive\",\n  \"agent_id\": \"{{agent_id}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Calls",
      "item": [
        {
          "name": "Start Call",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/call/start",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agent_id\": \"{{agent_id}}\",\n  \"customer_id\": \"{{customer_id}}\"\n}"
            }
          }
        },
        {
          "name": "End Call",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/call/end?call_id={{call_id}}"
          }
        },
        {
          "name": "List Calls",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/calls"
          }
        },
        {
          "name": "Get Call",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/call/{{call_id}}"
          }
        },
        {
          "name": "Get Transcript",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/transcript/{{call_id}}"
          }
        },
        {
          "name": "Get Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/summary/{{call_id}}"
          }
        },
        {
          "name": "Get Extracted Info",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/extracted-info/{{call_id}}"
          }
        }
      ]
    }
  ]
}
